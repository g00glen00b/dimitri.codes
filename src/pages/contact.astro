---
import { CONFIG } from "../config/config"
import SiteLayout from "../layouts/SiteLayout.astro"

const labelClass = "font-heading font-bold text-xs uppercase tracking-widest text-ink";
const fieldClass = "border-2 border-ink bg-bg px-3 py-2 w-full font-sans text-base text-ink placeholder:text-primary-light focus:outline-none focus:border-accent transition-colors duration-100";
---
<SiteLayout
  showHeaderFooter={true}
  disableComments={true}
  title="Contact"
  description={CONFIG.site.description}
  path="contact">
  <p>
    Feel free to reach out in case you have some suggestions to my website or new ideas I could try out for my next blogpost.
    If you're having a question about a blog post, please use the comment section under each blogpost, which is powered by <a href="https://utteranc.es/" target="_blank" rel="noopener noreferrer">utteranc.es</a> and GitHub.
  </p>
  <form
    class="flex flex-col gap-5 mt-6"
    name="contact"
    method="post"
    data-netlify="true"
    data-netlify-honeypot="special"
    data-netlify-recaptcha="true"
    action="/contact-confirm">

    <div class="flex flex-col gap-1.5">
      <label class={labelClass} for="name">Your name</label>
      <input class={fieldClass} type="text" id="name" name="name" placeholder="ex. Optimus Prime" />
    </div>

    <div class="hidden">
      <label for="special">Special</label>
      <input type="text" id="special" name="special" />
    </div>

    <div class="flex flex-col gap-1.5">
      <label class={labelClass} for="email">
        Your e-mail <sup class="text-accent font-bold">*</sup>
      </label>
      <input class={fieldClass} type="email" id="email" required name="email" placeholder="ex. optimus@transformers.net" />
    </div>

    <div class="flex flex-col gap-1.5">
      <label class={labelClass} for="title">Title</label>
      <input class={fieldClass} type="text" id="title" name="title" placeholder="A short description of your message" />
    </div>

    <div class="flex flex-col gap-1.5">
      <label class={labelClass} for="message">
        Your message <sup class="text-accent font-bold">*</sup>
      </label>
      <textarea class={fieldClass} rows="10" id="message" name="message" placeholder="Leave your message here"></textarea>
    </div>

    <div data-netlify-recaptcha="true"></div>

    <p class="text-xs text-primary-light m-0"><sup>*</sup> Fields marked with an asterisk are required.</p>

    <div>
      <button
        type="submit"
        class="inline-block px-5 py-3 font-heading font-bold text-sm uppercase tracking-widest text-ink bg-bg border-2 border-ink shadow-brut-sm transition-[box-shadow,transform] duration-100 hover:shadow-none hover:translate-x-1 hover:translate-y-1">
        Contact me
      </button>
    </div>
  </form>
</SiteLayout>
