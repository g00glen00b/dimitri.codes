---
import {type Tag} from '../models/Tag';
import {Icon} from 'astro-icon';
import {format} from 'date-fns';
import {type ReadTimeResults} from 'reading-time';
import BandContainer from './BandContainer.astro';

export interface Props {
  readingTime: ReadTimeResults;
  tags: Tag[];
  date: Date;
  title: string;
  featuredImage: string;
}
const {readingTime, tags, date, title, featuredImage} = Astro.props;
const readableDate = format(date, 'MMMM do, yyyy');
const minutesRead = Math.round(readingTime.minutes);
---
<BandContainer innerClass="pt-10 pb-8">
  <div class="bg-bg border-2 border-ink shadow-brut-sm px-6 pt-5 pb-4 flex gap-6 items-start max-sm:flex-col">
    {featuredImage && (
      <div class="shrink-0">
        <img
          src={featuredImage}
          alt=""
          class="w-20 h-auto"
        />
      </div>
    )}
    <div class="flex-1 min-w-0">
      <h1 class="font-heading font-extrabold text-[2rem] text-ink m-0 mb-4 leading-tight">{title}</h1>
      <dl class="flex flex-col gap-2 m-0">
        <div class="flex items-center gap-2">
          <dt class="m-0 flex items-center text-primary">
            <Icon name="mdi:calendar-blank-outline" aria-hidden="true" class="w-5 h-5 fill-current" />
          </dt>
          <dd class="m-0 text-sm" aria-label={`Posted at ${readableDate}`}>{readableDate}</dd>
        </div>
        <div class="flex items-center gap-2">
          <dt class="m-0 flex items-center text-primary">
            <Icon name="mdi:stopwatch-outline" aria-hidden="true" class="w-5 h-5 fill-current" />
          </dt>
          <dd class="m-0 text-sm">{minutesRead} minute read</dd>
        </div>
        {tags != null && (
          <div class="flex items-start gap-2">
            <dt class="m-0 flex items-center text-primary mt-0.5">
              <Icon name="mdi:tag-outline" aria-hidden="true" class="w-5 h-5 fill-current" />
            </dt>
            <dd class="m-0 flex flex-wrap gap-1.5">
              {tags.map(({name, path}) => (
                <a
                  href={`/tag/${path}`}
                  title={`View all posts tagged with ${name}`}
                  class="inline-block font-heading font-bold text-[0.6rem] uppercase tracking-widest text-ink bg-secondary border-[1.5px] border-ink px-2 py-0.5 no-underline hover:bg-accent transition-colors duration-150">
                  {name}
                </a>
              ))}
            </dd>
          </div>
        )}
      </dl>
    </div>
  </div>
</BandContainer>
<hr class="border-0 border-t-[3px] border-ink m-0" />
